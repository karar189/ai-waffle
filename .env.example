# Claude (required for Copilot chat + the yield-routing agent's reasoning layer)
CLAUDE_API_KEY=
# Optional: override the model Claude uses for agent decisions.
# CLAUDE_MODEL=claude-3-5-sonnet-latest

# CSPR.cloud access token (required for all Casper reads). Request one at https://cspr.cloud/
# Server-side only. NEVER expose this to the browser or commit it.
CSPR_CLOUD_API_KEY=

# Casper network selection: "testnet" (default) or "mainnet"
CASPER_NETWORK=testnet

# WCSPR contract package hash used to price LP pool reserves in CSPR.
# Testnet default is built in; set this to enable LP pricing on mainnet.
# WCSPR_CONTRACT_PACKAGE_HASH=

# CSPR.trade router package hash for LP execution (swap / add_liquidity_cspr).
# Testnet default is built in; override for mainnet or a different router.
# CSPR_TRADE_ROUTER_PACKAGE_HASH=

# Waffle Trade Agent Policy contract package hash.
# Deploy with: node --env-file=.env scripts/deploy-agent-policy.mjs
# Then register/update policy with: POST /api/agent/onchain-policy { "action": "register" }
# WAFFLE_AGENT_POLICY_PACKAGE_HASH=

# Optional overrides. Defaults are derived from CASPER_NETWORK in src/lib/casper/config.ts.
# CSPR_CLOUD_REST_URL=https://api.testnet.cspr.cloud
# CSPR_CLOUD_STREAM_URL=wss://streaming.testnet.cspr.cloud
# CSPR_CLOUD_NODE_RPC_URL=https://node.testnet.cspr.cloud
# CSPR_CLOUD_MCP_URL=https://mcp.testnet.cspr.cloud/mcp
# CSPR_X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# Agent auto-sign session key (server-side only, OPTIONAL).
# When set, small rebalances (<= autoSignLimit) are signed automatically.
# Without it, every move requires Casper Wallet approval.
# CASPER_SESSION_PRIVATE_KEY_HEX=
# CASPER_SESSION_KEY_ALGO=ed25519
# CASPER_SESSION_PRIVATE_KEY_PEM=/absolute/path/to/secret_key.pem

# Base URL the MCP server uses to reach the running Next.js agent API.
# AGENT_API_BASE=http://localhost:3001

# Background autonomy scheduler (server-side monitor -> decide -> execute loop).
# Starts automatically on server boot via src/instrumentation.ts. It keeps the
# agent "self-driving" with no dashboard open. Set AGENT_SCHEDULER=off to disable.
# AGENT_SCHEDULER=off
# Default seconds between autonomous cycles (also editable at runtime via the API).
# AGENT_TICK_INTERVAL_SEC=60

# FinArc backend (for Fetch ML Signal, forex/crypto data). Default: http://127.0.0.1:8000
# NEXT_PUBLIC_FINARC_API_URL=http://127.0.0.1:8000

# Agent reasoning LLM provider selection.
# The agent uses OpenAI when OPENAI_API_KEY is set, else Claude (CLAUDE_API_KEY).
# Force one explicitly with LLM_PROVIDER=openai | anthropic
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# LLM_PROVIDER=openai

# DEEPSEEK_API_KEY=
